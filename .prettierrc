{
  "semi":              true,
  "singleQuote":       true,
  "quoteProps":        "as-needed",
  "trailingComma":     "all",
  "tabWidth":          2,
  "useTabs":           false,
  "printWidth":        100,
  "bracketSpacing":    true,
  "arrowParens":       "always",
  "endOfLine":         "lf",
  "importOrder":       ["^@elorge/(.*)$", "^[./]"],
  "importOrderSeparation": true,
  "importOrderSortSpecifiers": true,
  "overrides": [
    {
      "files": ["*.json"],
      "options": { "printWidth": 80 }
    },
    {
      "files": ["*.md"],
      "options": {
        "proseWrap":  "always",
        "printWidth": 80
      }
    }
  ]
}
