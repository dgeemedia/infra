// apps/api/src/database/prisma/schema.prisma
// ════════════════════════════════════════════════════════════
//  Elorge Platform — Prisma Database Schema
//  PostgreSQL 16
// ════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Enums ─────────────────────────────────────────────────────

// ★ NEW
enum PartnerRole {
  ADMIN
  PARTNER
}

enum PartnerStatus {
  ACTIVE
  SUSPENDED
  PENDING_REVIEW
}

enum ApiKeyEnvironment {
  live
  sandbox
}

enum PayoutStatus {
  PENDING
  PROCESSING
  DELIVERED
  FAILED
  FLAGGED
}

enum WebhookDeliveryStatus {
  SUCCESS
  FAILED
  PENDING
}

enum AuditAction {
  CREATED
  UPDATED
  DELETED
  STATUS_CHANGED
  API_KEY_GENERATED
  API_KEY_REVOKED
  WEBHOOK_FIRED
  PAYOUT_QUEUED
  PAYOUT_DISPATCHED
  COMPLIANCE_PASSED
  COMPLIANCE_FLAGGED
}

// ── Partner ───────────────────────────────────────────────────
model Partner {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  passwordHash String?                             // ★ NEW — dashboard login
  role         PartnerRole   @default(PARTNER)     // ★ NEW — ADMIN | PARTNER
  country      String
  status       PartnerStatus @default(PENDING_REVIEW)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // Relations
  apiKeys        ApiKey[]
  payouts        Payout[]
  webhookConfigs WebhookConfig[]
  auditLogs      AuditLog[]

  @@map("partners")
}

// ── ApiKey ────────────────────────────────────────────────────
model ApiKey {
  id          String            @id @default(uuid())
  partnerId   String
  label       String
  keyHash     String            @unique
  keyPreview  String
  environment ApiKeyEnvironment @default(live)
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime          @default(now())

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId])
  @@index([keyHash])
  @@map("api_keys")
}

// ── Payout ────────────────────────────────────────────────────
model Payout {
  id               String       @id @default(uuid())
  partnerId        String
  partnerReference String
  sendAmount       Decimal      @db.Decimal(12, 2)
  sendCurrency     String
  nairaAmount      Decimal      @db.Decimal(14, 2)
  exchangeRate     Decimal      @db.Decimal(10, 4)
  fee              Decimal      @db.Decimal(10, 2)
  status           PayoutStatus @default(PENDING)
  pspReference     String?
  failureReason    String?
  bankSessionId    String?
  narration        String?
  deliveredAt      DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  partner           Partner           @relation(fields: [partnerId], references: [id])
  recipient         Recipient?
  webhookDeliveries WebhookDelivery[]

  @@unique([partnerId, partnerReference])
  @@index([partnerId])
  @@index([status])
  @@index([createdAt])
  @@map("payouts")
}

// ── Recipient ─────────────────────────────────────────────────
model Recipient {
  id            String   @id @default(uuid())
  payoutId      String   @unique
  fullName      String
  bankCode      String
  bankName      String
  accountNumber String
  phone         String?
  createdAt     DateTime @default(now())

  payout Payout @relation(fields: [payoutId], references: [id], onDelete: Cascade)

  @@index([accountNumber])
  @@map("recipients")
}

// ── WebhookConfig ─────────────────────────────────────────────
model WebhookConfig {
  id        String   @id @default(uuid())
  partnerId String
  url       String
  events    String[]
  isActive  Boolean  @default(true)
  secret    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  partner           Partner           @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  webhookDeliveries WebhookDelivery[]

  @@index([partnerId])
  @@map("webhook_configs")
}

// ── WebhookDelivery ───────────────────────────────────────────
model WebhookDelivery {
  id           String                @id @default(uuid())
  payoutId     String
  webhookId    String
  event        String
  payload      Json
  responseCode Int?
  responseBody String?
  attempt      Int                   @default(1)
  status       WebhookDeliveryStatus @default(PENDING)
  nextRetryAt  DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  payout  Payout        @relation(fields: [payoutId],  references: [id])
  webhook WebhookConfig @relation(fields: [webhookId], references: [id])

  @@index([payoutId])
  @@index([webhookId])
  @@index([status, nextRetryAt])
  @@map("webhook_deliveries")
}

// ── AuditLog ──────────────────────────────────────────────────
model AuditLog {
  id         String      @id @default(uuid())
  partnerId  String?
  entityType String
  entityId   String
  action     AuditAction
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  partner Partner? @relation(fields: [partnerId], references: [id])

  @@index([partnerId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}