generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────
// PARTNER
// Partners are UK-licensed entities that source their own FX.
// They pre-fund a Naira wallet with Elorge (balanceKobo).
// Elorge routes disbursements via Flutterwave and earns a small
// per-payout Naira fee.
// ─────────────────────────────────────────────────────────────
model Partner {
  id                  String               @id @default(uuid())
  name                String
  email               String               @unique
  country             String
  status              PartnerStatus        @default(PENDING_REVIEW)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  passwordHash        String?
  role                PartnerRole          @default(PARTNER)

  // Balance stored in kobo (1 NGN = 100 kobo) to avoid float drift.
  // Partners fund this wallet; Elorge debits nairaAmount + fee per payout.
  balanceKobo         Int                  @default(0)

  mustChangePassword  Boolean              @default(false)

  apiKeys             ApiKey[]
  auditLogs           AuditLog[]
  balanceTransactions BalanceTransaction[]
  notifications       Notification[]
  payouts             Payout[]
  webhookConfigs      WebhookConfig[]

  @@map("partners")
}

// ─────────────────────────────────────────────────────────────
// API KEY
// ─────────────────────────────────────────────────────────────
model ApiKey {
  id          String            @id @default(uuid())
  partnerId   String
  label       String
  keyHash     String            @unique
  keyPreview  String
  environment ApiKeyEnvironment @default(live)
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime          @default(now())
  partner     Partner           @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId])
  @@index([keyHash])
  @@map("api_keys")
}

// ─────────────────────────────────────────────────────────────
// PAYOUT
//
// Simplified flow:
//  1. Partner sends { nairaAmount, recipient, partnerReference }
//  2. Elorge debits (nairaAmount + feeKobo) from partner wallet
//  3. Elorge transfers exactly nairaAmount to recipient via Flutterwave
//  4. Elorge retains feeKobo as platform revenue
//
// No sendCurrency / exchangeRate stored — partner owns FX entirely.
// exchangeRateAudit is optional and never used in calculations.
// ─────────────────────────────────────────────────────────────
model Payout {
  id                String               @id @default(uuid())
  partnerId         String
  partnerReference  String

  // Amount to credit to recipient's Nigerian bank account (kobo)
  nairaAmountKobo   Int

  // Elorge platform fee deducted from partner wallet (kobo)
  feeKobo           Int                  @default(0)

  // Optional: partner's declared FX rate for audit / reconciliation only.
  // Elorge never reads this for any calculation.
  exchangeRateAudit Decimal?             @db.Decimal(10, 4)

  status            PayoutStatus         @default(PENDING)
  pspReference      String?
  failureReason     String?
  bankSessionId     String?
  narration         String?
  deliveredAt       DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  balanceTransactions BalanceTransaction[]
  partner             Partner              @relation(fields: [partnerId], references: [id])
  recipient           Recipient?
  webhookDeliveries   WebhookDelivery[]

  @@unique([partnerId, partnerReference])
  @@index([partnerId])
  @@index([status])
  @@index([createdAt])
  @@map("payouts")
}

// ─────────────────────────────────────────────────────────────
// RECIPIENT
// ─────────────────────────────────────────────────────────────
model Recipient {
  id            String   @id @default(uuid())
  payoutId      String   @unique
  fullName      String
  bankCode      String
  bankName      String
  accountNumber String
  phone         String?
  createdAt     DateTime @default(now())
  payout        Payout   @relation(fields: [payoutId], references: [id], onDelete: Cascade)

  @@index([accountNumber])
  @@map("recipients")
}

// ─────────────────────────────────────────────────────────────
// WEBHOOK CONFIG
// ─────────────────────────────────────────────────────────────
model WebhookConfig {
  id                String            @id @default(uuid())
  partnerId         String
  url               String
  events            String[]
  isActive          Boolean           @default(true)
  secret            String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  partner           Partner           @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  webhookDeliveries WebhookDelivery[]

  @@index([partnerId])
  @@map("webhook_configs")
}

// ─────────────────────────────────────────────────────────────
// WEBHOOK DELIVERY
// ─────────────────────────────────────────────────────────────
model WebhookDelivery {
  id           String                @id @default(uuid())
  payoutId     String
  webhookId    String
  event        String
  payload      Json
  responseCode Int?
  responseBody String?
  attempt      Int                   @default(1)
  status       WebhookDeliveryStatus @default(PENDING)
  nextRetryAt  DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  payout       Payout                @relation(fields: [payoutId], references: [id])
  webhook      WebhookConfig         @relation(fields: [webhookId], references: [id])

  @@index([payoutId])
  @@index([webhookId])
  @@index([status, nextRetryAt])
  @@map("webhook_deliveries")
}

// ─────────────────────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────────────────────
model AuditLog {
  id         String      @id @default(uuid())
  partnerId  String?
  entityType String
  entityId   String
  action     AuditAction
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())
  partner    Partner?    @relation(fields: [partnerId], references: [id])

  @@index([partnerId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────
// NOTIFICATION
// ─────────────────────────────────────────────────────────────
model Notification {
  id        String           @id @default(uuid())
  partnerId String
  type      NotificationType
  title     String
  body      String
  read      Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())
  partner   Partner          @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId, read])
  @@index([partnerId, createdAt])
  @@map("notifications")
}

// ─────────────────────────────────────────────────────────────
// BALANCE TRANSACTION
// All amounts in kobo (1/100 of a Naira).
//
// CREDIT  — partner tops up Naira wallet (admin confirms receipt)
// DEBIT   — payout nairaAmount + fee deducted on payout creation
// REFUND  — fee returned to partner if payout fails
// ─────────────────────────────────────────────────────────────
model BalanceTransaction {
  id                 String                 @id @default(dbgenerated("(gen_random_uuid())::text"))
  partnerId          String
  type               BalanceTransactionType
  amountKobo         Int
  balanceAfterKobo   Int
  description        String
  payoutId           String?
  createdAt          DateTime               @default(now())
  partner            Partner                @relation(fields: [partnerId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  payout             Payout?                @relation(fields: [payoutId], references: [id], onUpdate: NoAction)

  @@index([partnerId])
  @@index([partnerId, type])
  @@index([createdAt])
  @@map("balance_transactions")
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────
enum PartnerRole {
  ADMIN
  PARTNER
}

enum PartnerStatus {
  ACTIVE
  SUSPENDED
  PENDING_REVIEW
}

enum ApiKeyEnvironment {
  live
  sandbox
}

enum PayoutStatus {
  PENDING
  PROCESSING
  DELIVERED
  FAILED
  FLAGGED
}

enum WebhookDeliveryStatus {
  SUCCESS
  FAILED
  PENDING
}

enum AuditAction {
  CREATED
  UPDATED
  DELETED
  STATUS_CHANGED
  API_KEY_GENERATED
  API_KEY_REVOKED
  WEBHOOK_FIRED
  PAYOUT_QUEUED
  PAYOUT_DISPATCHED
  COMPLIANCE_PASSED
  COMPLIANCE_FLAGGED
}

enum NotificationType {
  PAYOUT_DELIVERED
  PAYOUT_FAILED
  PAYOUT_FLAGGED
  WEBHOOK_FAILED
  API_KEY_CREATED
  ACCOUNT_SUSPENDED
  SYSTEM
}

enum BalanceTransactionType {
  CREDIT
  DEBIT
  REFUND
}
