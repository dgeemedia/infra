generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Partner {
  id                  String               @id @default(uuid())
  name                String
  email               String               @unique
  country             String
  status              PartnerStatus        @default(PENDING_REVIEW)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  passwordHash        String?
  role                PartnerRole          @default(PARTNER)
  balanceKobo         Int                  @default(0)
  mustChangePassword  Boolean              @default(false)
  flwVanAccountNumber String?
  flwVanBankName      String?
  flwVanBankCode      String?
  flwVanReference     String?              @unique
  flwVanCreatedAt     DateTime?            @db.Timestamptz(6)
  apiKeys             ApiKey[]
  auditLogs           AuditLog[]
  balanceTransactions BalanceTransaction[]
  notifications       Notification[]
  payouts             Payout[]
  webhookConfigs      WebhookConfig[]

  @@map("partners")
}

model ApiKey {
  id          String            @id @default(uuid())
  partnerId   String
  label       String
  keyHash     String            @unique
  keyPreview  String
  environment ApiKeyEnvironment @default(live)
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime          @default(now())
  partner     Partner           @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId])
  @@index([keyHash])
  @@map("api_keys")
}

model Payout {
  id                String  @id @default(uuid())
  partnerId         String
  partnerReference  String

  // Amount credited to the recipient (kobo). Exact. Never modified.
  nairaAmountKobo   Int

  // Elorge's platform fee (kobo). Charged to partner wallet.
  feeKobo           Int     @default(0)

  // Partner's declared FX rate — audit trail only, never used in calculations.
  exchangeRateAudit Decimal? @db.Decimal(10, 4)

  status        PayoutStatus @default(PENDING)
  pspReference  String?
  failureReason String?
  bankSessionId String?
  narration     String?
  deliveredAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  balanceTransactions BalanceTransaction[]
  partner             Partner              @relation(fields: [partnerId], references: [id])
  recipient           Recipient?
  webhookDeliveries   WebhookDelivery[]

  @@unique([partnerId, partnerReference])
  @@index([partnerId])
  @@index([status])
  @@index([createdAt])
  @@map("payouts")
}

model Recipient {
  id            String   @id @default(uuid())
  payoutId      String   @unique
  fullName      String
  bankCode      String
  bankName      String
  accountNumber String
  phone         String?
  createdAt     DateTime @default(now())
  payout        Payout   @relation(fields: [payoutId], references: [id], onDelete: Cascade)

  @@index([accountNumber])
  @@map("recipients")
}

model WebhookConfig {
  id                String            @id @default(uuid())
  partnerId         String
  url               String
  events            String[]
  isActive          Boolean           @default(true)
  secret            String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  partner           Partner           @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  webhookDeliveries WebhookDelivery[]

  @@index([partnerId])
  @@map("webhook_configs")
}

model WebhookDelivery {
  id           String                @id @default(uuid())
  payoutId     String
  webhookId    String
  event        String
  payload      Json
  responseCode Int?
  responseBody String?
  attempt      Int                   @default(1)
  status       WebhookDeliveryStatus @default(PENDING)
  nextRetryAt  DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  payout       Payout                @relation(fields: [payoutId], references: [id])
  webhook      WebhookConfig         @relation(fields: [webhookId], references: [id])

  @@index([payoutId])
  @@index([webhookId])
  @@index([status, nextRetryAt])
  @@map("webhook_deliveries")
}

model AuditLog {
  id         String      @id @default(uuid())
  partnerId  String?
  entityType String
  entityId   String
  action     AuditAction
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())
  partner    Partner?    @relation(fields: [partnerId], references: [id])

  @@index([partnerId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Notification {
  id        String           @id @default(uuid())
  partnerId String
  type      NotificationType
  title     String
  body      String
  read      Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())
  partner   Partner          @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId, read])
  @@index([partnerId, createdAt])
  @@map("notifications")
}

model BalanceTransaction {
  id               String                 @id @default(dbgenerated("(gen_random_uuid())::text"))
  partnerId        String
  type             BalanceTransactionType
  amountKobo       Int
  balanceAfterKobo Int
  description      String
  payoutId         String?
  createdAt        DateTime               @default(now())
  partner          Partner                @relation(fields: [partnerId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  payout           Payout?                @relation(fields: [payoutId], references: [id], onUpdate: NoAction)

  @@index([partnerId])
  @@index([partnerId, type])
  @@index([createdAt])
  @@index([createdAt], map: "idx_bal_created")
  @@index([partnerId], map: "idx_bal_partner")
  @@index([partnerId, type], map: "idx_bal_type")
  @@map("balance_transactions")
}

enum PartnerRole {
  ADMIN
  PARTNER
}

enum PartnerStatus {
  ACTIVE
  SUSPENDED
  PENDING_REVIEW
}

enum ApiKeyEnvironment {
  live
  sandbox
}

enum PayoutStatus {
  PENDING
  PROCESSING
  DELIVERED
  FAILED
  FLAGGED
}

enum WebhookDeliveryStatus {
  SUCCESS
  FAILED
  PENDING
}

enum BalanceTransactionType {
  CREDIT
  DEBIT
  REFUND
}

enum AuditAction {
  CREATED
  UPDATED
  DELETED
  STATUS_CHANGED
  API_KEY_GENERATED
  API_KEY_REVOKED
  WEBHOOK_FIRED
  PAYOUT_QUEUED
  PAYOUT_DISPATCHED
  COMPLIANCE_PASSED
  COMPLIANCE_FLAGGED
}

enum NotificationType {
  PAYOUT_DELIVERED
  PAYOUT_FAILED
  PAYOUT_FLAGGED
  WEBHOOK_FAILED
  API_KEY_CREATED
  ACCOUNT_SUSPENDED
  SYSTEM
}
