{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module":          "CommonJS",
    "declaration":     true,
    "removeComments":  true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target":          "ES2022",
    "sourceMap":       true,
    "outDir":          "./dist",
    "baseUrl":         "./",
    "incremental":     true,
    "paths": {
      "@elorge/types":     ["../../packages/types/src"],
      "@elorge/constants": ["../../packages/constants/src"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts"]
}
