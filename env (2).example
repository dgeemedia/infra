# ════════════════════════════════════════════════════════════
#  ELORGE TECHNOLOGIES — Environment Variables Template
#  Copy to apps/api/.env and apps/dashboard/.env
#  Fill in real values. NEVER commit the real .env file.
# ════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development           # development | staging | production
PORT=3001

PLATFORM_NAME=Elorge Payout Platform
PLATFORM_EMAIL=platform@elorge.com
SUPPORT_EMAIL=support@elorge.com

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=
DIRECT_URL=

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=change_this_in_production
JWT_EXPIRES_IN=7d

# ── API Keys ─────────────────────────────────────────────────
API_KEY_PREFIX=el_live_
API_KEY_SANDBOX_PREFIX=el_test_

# ── Flutterwave ───────────────────────────────────────────────
# Primary PSP for NGN disbursements and partner VANs.
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-your-key-here
FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3

# Secret Hash — set this to any random string, then enter the
# same value in Flutterwave dashboard → Settings → Webhooks → Secret Hash.
# Elorge uses this to verify inbound webhook signatures.
FLUTTERWAVE_WEBHOOK_HASH=pick_any_random_string_and_paste_it_in_flutterwave_too

# ── Platform fee (Naira, in kobo) ────────────────────────────
# Used for low-balance alerts and VAN top-up notifications only.
# The actual per-payout fee is calculated by the tier schedule
# in payouts.service.ts (calculateFeeKobo).
# Override PLATFORM_FEE_KOBO only if you want a flat fee instead.
#
# Tier schedule (default):
#   ≤ ₦50,000    → ₦150 fee  (15000 kobo)
#   ≤ ₦200,000   → ₦250 fee  (25000 kobo)
#   ≤ ₦1,000,000 → ₦400 fee  (40000 kobo)
#   > ₦1,000,000 → ₦600 fee  (60000 kobo)
#
# PLATFORM_FEE_KOBO=25000   # uncomment to override with flat fee

# ── Payout limits ─────────────────────────────────────────────
MIN_PAYOUT_KOBO=10000          # ₦100 minimum
MAX_PAYOUT_KOBO=5000000000     # ₦50,000,000 maximum

# ── Partner wallet floor ──────────────────────────────────────
# Minimum kobo a partner must retain after a payout + fee deduction.
# 0 = no floor. Raise to e.g. 500000 (₦5,000) to require a buffer.
MIN_PARTNER_BALANCE_KOBO=0

# ── Compliance ────────────────────────────────────────────────
# OpenSanctions — covers OFAC, UN, EU, UK HMT lists.
# Free tier: 10,000 req/day. Leave blank in dev to skip screening.
OPEN_SANCTIONS_API_KEY=

# ── Outbound Webhook Delivery ─────────────────────────────────
WEBHOOK_SECRET=change_this
WEBHOOK_MAX_RETRIES=5
WEBHOOK_RETRY_DELAY_MS=5000

# ── Dashboard (Next.js) ───────────────────────────────────────
NEXTAUTH_SECRET=change_this_in_production
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
